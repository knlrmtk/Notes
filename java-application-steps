##### Update POM file:-
vim sbi-app/pom.xml

<properties>
    <maven.compiler.source>21</maven.compiler.source>
    <maven.compiler.target>21</maven.compiler.target>
</properties>


<dependencies>

    <!-- Micrometer Core -->
    <dependency>
        <groupId>io.micrometer</groupId>
        <artifactId>micrometer-core</artifactId>
        <version>1.13.0</version>
    </dependency>

    <!-- Prometheus Registry -->
    <dependency>
        <groupId>io.micrometer</groupId>
        <artifactId>micrometer-registry-prometheus</artifactId>
        <version>1.13.0</version>
    </dependency>

</dependencies>

##### Add filed section in POM file:-

<build>
    <plugins>

        <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-compiler-plugin</artifactId>
            <version>3.11.0</version>

            <configuration>
                <source>21</source>
                <target>21</target>
            </configuration>
        </plugin>

        <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-shade-plugin</artifactId>
            <version>3.5.0</version>

            <executions>
                <execution>
                    <phase>package</phase>

                    <goals>
                        <goal>shade</goal>
                    </goals>

                    <configuration>

                        <transformers>

                            <transformer implementation=
                              "org.apache.maven.plugins.shade.resource.ManifestResourceTransformer">

                                <mainClass>com.sbi.app.Application</mainClass>

                            </transformer>

                        </transformers>

                    </configuration>
                </execution>
            </executions>

        </plugin>

    </plugins>
</build>


##### Create directory and file:-
mkdir -p src/main/java/com/sbi/app/monitoring
vim src/main/java/com/sbi/app/monitoring/MetricsServer.java

package com.sbi.app.monitoring;
public class MetricsServer {

    public static void start() {
        System.out.println("Metrics Server Started");
    }
}


##### Update Application file:-

src/main/java/com/sbi/app/Application.java

package com.sbi.app;
import com.sbi.app.monitoring.MetricsServer;
public class Application {

    public static void main(String[] args) {

        MetricsServer.start();

        System.out.println("SBI App Started");
    }
}


##### Run Application using command:-
	java -jar target/sbi-app-1.0-SNAPSHOT.jar
	java -cp target/sbi-app-1.0-SNAPSHOT.jar com.sbi.app.Application

